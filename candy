#include <vector>
#include <numeric>
#include <algorithm>

using namespace std;

class Solution {
public:
    int candy(vector<int>& ratings) {
        int n = ratings.size();
        if (n <= 1) return n;

        // Initialize every child with 1 candy
        vector<int> candies(n, 1);

        // First Pass: Left to Right
        // If current child has higher rating than left neighbor, give more
        for (int i = 1; i < n; i++) {
            if (ratings[i] > ratings[i - 1]) {
                candies[i] = candies[i - 1] + 1;
            }
        }

        // Second Pass: Right to Left
        // If current child has higher rating than right neighbor, give more
        // We use max() to keep the higher value from the first pass
        for (int i = n - 2; i >= 0; i--) {
            if (ratings[i] > ratings[i + 1]) {
                candies[i] = max(candies[i], candies[i + 1] + 1);
            }
        }

        // Return the sum of all candies in the vector
        return accumulate(candies.begin(), candies.end(), 0);
    }
};
